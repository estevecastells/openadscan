{
  "name": "openadscan",
  "version": "0.1.0",
  "description": "Open-source, self-hosted alternative to Adthena. Brand presence and SEO/SEM intelligence on Cloudflare Workers.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --mode client",
    "preview": "wrangler dev",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx src/seed/demo.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.2",
    "@noble/hashes": "^1.5.0",
    "drizzle-orm": "^0.36.4",
    "echarts": "^6.1.0",
    "hono": "^4.6.12",
    "honox": "^0.1.36",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/vitest-pool-workers": "^0.5.30",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.17.0",
    "@vitest/coverage-v8": "2.1.9",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.6",
    "wrangler": "^3.91.0"
  }
}
